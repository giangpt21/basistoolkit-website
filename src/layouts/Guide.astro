---
import Base from '../layouts/Base.astro';
const { title, description, path, tag = 'Guide', updated, keywords } = Astro.props;

const site = 'https://basistoolkit.com';
// Article + breadcrumb structured data helps Google show these guides in search
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "TechArticle",
      "headline": title,
      "description": description,
      "author": { "@type": "Person", "name": "Giang Pham" },
      "publisher": { "@type": "Organization", "name": "BasisToolkit" },
      "mainEntityOfPage": site + path,
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": site + "/" },
        { "@type": "ListItem", "position": 2, "name": "Guides", "item": site + "/guides/" },
        { "@type": "ListItem", "position": 3, "name": title, "item": site + path },
      ],
    },
  ],
};
---
<Base title={`${title} | BasisToolkit`} description={description} path={path} keywords={keywords} jsonLd={jsonLd}>
  <article class="guide">
    <div class="wrap guide-wrap">
      <a class="back" href="/guides/">← All guides</a>
      <span class="eyebrow">{tag}</span>
      <h1>{title}</h1>
      {updated && <p class="updated muted">Updated {updated}</p>}
      <div class="prose">
        <slot />
      </div>

      <div class="guide-cta">
        <div>
          <strong>Get the tool</strong>
          <p class="muted">Free, portable, Windows 10/11.</p>
        </div>
        <a class="btn btn-primary" href="/download/">Download</a>
      </div>
    </div>
  </article>

  <style>
    .guide-wrap { max-width: 760px; padding-block: clamp(2rem, 5vw, 3.5rem); }
    .back { font-size: 0.9rem; color: var(--slate); display: inline-block; margin-bottom: 1.2rem; }
    .back:hover { color: var(--blue); }
    .guide h1 { font-size: var(--step-3); margin-bottom: 0.4rem; }
    .updated { font-size: 0.85rem; margin-bottom: 2rem; }

    .prose { font-size: 1.05rem; line-height: 1.75; color: #26374B; }
    .prose :global(h2) { font-size: var(--step-2); margin-top: 2.4rem; margin-bottom: 0.6rem; color: var(--ink); }
    .prose :global(h3) { font-size: var(--step-1); margin-top: 1.8rem; margin-bottom: 0.4rem; color: var(--ink); }
    .prose :global(p) { margin-bottom: 1.1rem; }
    .prose :global(ul), .prose :global(ol) { margin: 0 0 1.2rem; padding-left: 1.3rem; }
    .prose :global(li) { margin-bottom: 0.5rem; }
    .prose :global(pre) { background: var(--ink); color: #D7E6F5; padding: 1rem 1.2rem; border-radius: var(--radius-sm); overflow-x: auto; font-size: 0.88rem; line-height: 1.6; margin: 0 0 1.3rem; }
    .prose :global(pre code) { background: none; border: none; color: inherit; padding: 0; }
    .prose :global(blockquote) { border-left: 3px solid var(--blue); background: var(--surface); margin: 0 0 1.3rem; padding: 0.8rem 1.2rem; border-radius: 0 8px 8px 0; color: var(--slate); }
    .prose :global(img) { max-width: 100%; border-radius: var(--radius); border: 1px solid var(--line); }
    .prose :global(table) { width: 100%; border-collapse: collapse; margin: 0 0 1.3rem; font-size: 0.95rem; }
    .prose :global(th), .prose :global(td) { border: 1px solid var(--line); padding: 0.55rem 0.75rem; text-align: left; }
    .prose :global(th) { background: var(--surface); font-family: var(--font-display); }

    .guide-cta { display: flex; align-items: center; justify-content: space-between; gap: 1rem;
      margin-top: 3rem; padding: 1.4rem 1.6rem; background: var(--surface); border: 1px solid var(--line);
      border-radius: var(--radius); flex-wrap: wrap; }
    .guide-cta strong { font-family: var(--font-display); font-size: 1.05rem; }
    .guide-cta p { margin: 0; font-size: 0.9rem; }
  </style>
</Base>
