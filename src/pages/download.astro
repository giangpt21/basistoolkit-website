---
import Base from '../layouts/Base.astro';

// Direct download link (SourceForge, v1.1.1)
const downloadUrl = 'https://sourceforge.net/projects/sap-logon-transfer/files/v1.1.1/SAP%20Logon%20Transfer.zip/download';

const version = '1.1.1';
const requirements = [
  'Windows 10 or Windows 11',
  'No install needed — single portable .exe',
  'No .NET runtime required',
];

// Version history (most recent first)
const history = [
  {
    v: '1.1.1',
    date: 'Current',
    notes: [
      'Added Thai to the interface — now seven languages in total.',
      'Polished the system list: clearer folder and server icons, aligned columns.',
      'Packaged as a single self-contained .exe — no .NET runtime needed.',
    ],
  },
  {
    v: '1.1.0',
    date: 'Earlier',
    notes: [
      'Added Compare, to see what differs between two configurations.',
      'Added an Export report (CSV) of every system, server and router.',
      'Import preview now shows new vs. duplicate before writing.',
    ],
  },
  {
    v: '1.0.0',
    date: 'First stable release',
    notes: [
      'Export and import your system list between machines.',
      'Keeps folders, SAP routers and logon groups intact.',
      'Cloud backup and restore via your OneDrive, Google Drive or Dropbox folder.',
      'Six-language interface; a .bak backup written before every import.',
    ],
  },
];
---
<Base
  title="Download SAP Logon Transfer — free | BasisToolkit"
  description="Download SAP Logon Transfer for Windows. Free portable tool to move, back up and document your SAP Logon system list. No install, no passwords stored."
  path="/download/"
>
  <section class="dl">
    <div class="wrap dl-inner">
      <div class="dl-main">
        <span class="eyebrow">Download · v{version}</span>
        <h1>SAP Logon Transfer</h1>
        <p class="lead muted">
          A free, portable Windows app that moves your SAP connections between
          machines — folders, routers and logon groups intact — and lets you share
          or back up exactly the systems you choose.
        </p>

        <div class="dl-buttons">
          <a class="btn btn-primary btn-lg" href={downloadUrl}>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 3v12m0 0l-4-4m4 4l4-4M5 21h14"/></svg>
            Download .exe (Windows)
          </a>
        </div>
        <p class="dl-note muted">
          Windows may show a SmartScreen warning for a new unsigned app — choose
          <em>More info → Run anyway</em>. The tool only reads and writes your own
          SAP connection settings; it touches nothing else.
        </p>
      </div>

      <aside class="dl-card">
        <h2>Requirements</h2>
        <ul class="req">
          {requirements.map((r) => (
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#107E3E" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
              <span>{r}</span>
            </li>
          ))}
        </ul>
        <div class="req-safe">
          <strong>Safe by design</strong>
          <p class="muted">Only connection details are handled. SAP Logon never stores
          passwords in these files, and neither does the tool.</p>
        </div>
      </aside>
    </div>
  </section>

  <section class="section section-tint" id="history">
    <div class="wrap history-wrap">
      <span class="eyebrow">Version history</span>
      <h2>What's changed</h2>
      <div class="timeline">
        {history.map((rel) => (
          <div class="rel">
            <div class="rel-head">
              <span class="rel-v">v{rel.v}</span>
              <span class="rel-date muted">{rel.date}</span>
            </div>
            <ul class="rel-notes">
              {rel.notes.map((n) => <li>{n}</li>)}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <style>
    .dl { padding-block: clamp(2.5rem, 6vw, 4.5rem); }
    .dl-inner { display: grid; grid-template-columns: 1.4fr 1fr; gap: clamp(1.5rem, 4vw, 3rem); align-items: start; }
    .dl-main h1 { font-size: var(--step-3); }
    .dl-main .lead { font-size: var(--step-1); max-width: 48ch; }
    .dl-buttons { display: flex; gap: 0.8rem; margin: 1.8rem 0 1rem; flex-wrap: wrap; }
    .btn-lg { padding: 0.9rem 1.6rem; font-size: var(--step-0); }
    .dl-note { font-size: 0.9rem; max-width: 52ch; }

    .dl-card { background: #fff; border: 1px solid var(--line); border-radius: var(--radius); padding: 1.6rem; }
    .dl-card h2 { font-size: var(--step-1); margin-bottom: 1rem; }
    .req { list-style: none; margin: 0 0 1.3rem; padding: 0; display: flex; flex-direction: column; gap: 0.7rem; }
    .req li { display: flex; gap: 0.6rem; align-items: flex-start; font-size: 0.95rem; }
    .req li svg { flex: none; margin-top: 3px; }
    .req-safe { border-top: 1px solid var(--line); padding-top: 1.1rem; }
    .req-safe strong { color: var(--green); font-size: 0.95rem; }
    .req-safe p { font-size: 0.9rem; margin: 0.3rem 0 0; }

    .history-wrap { max-width: 760px; }
    .history-wrap h2 { font-size: var(--step-2); margin-bottom: 1.8rem; }
    .timeline { display: flex; flex-direction: column; gap: 1.4rem; }
    .rel { background: #fff; border: 1px solid var(--line); border-left: 3px solid var(--blue); border-radius: var(--radius); padding: 1.3rem 1.5rem; }
    .rel-head { display: flex; align-items: baseline; gap: 0.8rem; margin-bottom: 0.8rem; }
    .rel-v { font-family: var(--font-display); font-weight: 700; font-size: 1.15rem; color: var(--blue); }
    .rel-date { font-size: 0.85rem; }
    .rel-notes { margin: 0; padding-left: 1.1rem; display: flex; flex-direction: column; gap: 0.4rem; }
    .rel-notes li { font-size: 0.95rem; color: var(--slate); }

    @media (max-width: 760px) {
      .dl-inner { grid-template-columns: 1fr; }
    }
  </style>
</Base>
